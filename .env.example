# Copy to .env and fill in real values. .env is gitignored — never commit secrets.

# Groq API key — https://console.groq.com/keys
GROQ_API_KEY=

# NVIDIA NIM API key — https://build.nvidia.com (starts with nvapi-)
NVIDIA_API_KEY=

# true  = demo-safe mock pipeline (default, no keys needed)
# false = live Groq + NVIDIA calls (requires keys above)
MOCK_MODE=true
